{
  "name": "rbc-recurrence",
  "version": "0.1.0",
  "description": "The missing recurrence plugin for React Big Calendar — expand recurring events into the visible range with zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -p tsconfig.build.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts,.tsx",
    "format": "prettier --write src tests",
    "size": "size-limit",
    "demo": "cd examples/demo-app && npm run dev"
  },
  "keywords": [
    "react-big-calendar",
    "recurrence",
    "recurring-events",
    "rrule",
    "calendar",
    "react",
    "scheduling"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glue-berlin/rbc-recurrence"
  },
  "homepage": "https://glue.berlin/rbc-recurrence",
  "bugs": {
    "url": "https://github.com/glue-berlin/rbc-recurrence/issues"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-big-calendar": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-big-calendar": { "optional": true }
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-big-calendar": "^1.8.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^24.1.0",
    "moment": "^2.30.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-big-calendar": "^1.19.0",
    "react-dom": "^18.3.0",
    "size-limit": "^11.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.6.0"
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "5 kB"
    },
    {
      "path": "./dist/react.js",
      "limit": "10 kB"
    }
  ]
}
